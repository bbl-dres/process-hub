    <!-- Start event -->
    <bpmn:startEvent id="start_1" name="TQ Kauf- / Baurechtsvertrag auszufertigen">
      <bpmn:outgoing>flow_01</bpmn:outgoing>
    </bpmn:startEvent>

    <!-- Tasks -->
    <bpmn:task id="task_01_auftrag_ueberpruefen" name="Auftrag überprüfen (TQ.21.00.00.15.01)">
      <bpmn:incoming>flow_01</bpmn:incoming>
      <bpmn:outgoing>flow_02</bpmn:outgoing>
    </bpmn:task>

    <bpmn:exclusiveGateway id="gw_01" name="">
      <bpmn:incoming>flow_02</bpmn:incoming>
      <bpmn:outgoing>flow_03</bpmn:outgoing>
      <bpmn:outgoing>flow_04</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:task id="task_02_auftrag_zurueckgeben" name="Auftrag zurückgeben (TQ.21.00.00.15.02)">
      <bpmn:incoming>flow_04</bpmn:incoming>
      <bpmn:outgoing>flow_05</bpmn:outgoing>
    </bpmn:task>

    <bpmn:endEvent id="end_zurueckgegeben" name="TQ Auftrag an PFM zurückgegeben">
