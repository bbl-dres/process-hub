        <bpmn:flowNodeRef>task_11_mutationsblatt_ausfuellen</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>task_12_anlagenbuchhaltung</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>task_13_dossier_erstellen</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>end_verurkundet</bpmn:flowNodeRef>
