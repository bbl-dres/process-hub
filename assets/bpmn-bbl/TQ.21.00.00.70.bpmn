    <bpmn:sequenceFlow id="flow_09" name="ja" sourceRef="gw_02" targetRef="gw_merge"/>
    <bpmn:sequenceFlow id="flow_10" name="nein" sourceRef="gw_02" targetRef="task_06_bewirtschaftung"/>
    <bpmn:sequenceFlow id="flow_11" sourceRef="task_06_bewirtschaftung" targetRef="end_1"/>
    <bpmn:sequenceFlow id="flow_12" sourceRef="gw_merge" targetRef="task_07_folgetaetigkeiten"/>
    <bpmn:sequenceFlow id="flow_13" sourceRef="task_07_folgetaetigkeiten" targetRef="task_08_orientieren_uebergeben"/>
