    id="definitions_TQ_21_00_00_70"
    targetNamespace="http://process-hub.local/bpmn">
  <bpmn:process id="proc_TQ_21_00_00_70" name="TQ.21.00.00.70 Auflösung Anmiete, Pacht" isExecutable="false">
    <bpmn:laneSet id="laneSet_1">
      <bpmn:lane id="lane_extern" name="Externe (Vermieter / Mieter)"/>
      <bpmn:lane id="lane_lcdm" name="TQ LCDM / LIG / INV">
        <bpmn:flowNodeRef>start_1</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>task_01_fall_bestimmen</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>task_02_fristen_pruefen</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>gw_01</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>task_03_kuendigung_schreiben</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>task_04_kuendigung_entgegennehmen</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>task_05_kuendigung_pruefen</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>gw_02</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>task_06_bewirtschaftung</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>gw_merge</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>task_07_folgetaetigkeiten</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>task_08_orientieren_uebergeben</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>task_09_umsetzung_unterhalt</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>task_10_sap_fertigmeldung</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>end_1</bpmn:flowNodeRef>
      </bpmn:lane>
    </bpmn:laneSet>

    <!-- Start event -->
    <bpmn:startEvent id="start_1" name="TQ Auftrag Auflösung Anmiete, Pacht">
      <bpmn:outgoing>flow_01</bpmn:outgoing>
    </bpmn:startEvent>

    <!-- Tasks -->
    <bpmn:task id="task_01_fall_bestimmen" name="Fall bestimmen (TQ.21.00.00.70.01)">
      <bpmn:incoming>flow_01</bpmn:incoming>
      <bpmn:outgoing>flow_02</bpmn:outgoing>
    </bpmn:task>

    <bpmn:task id="task_02_fristen_pruefen" name="Fristen prüfen (TQ.21.00.00.70.02)">
      <bpmn:incoming>flow_02</bpmn:incoming>
      <bpmn:outgoing>flow_03</bpmn:outgoing>
    </bpmn:task>

    <bpmn:exclusiveGateway id="gw_01" name="Kündigung durch">
      <bpmn:incoming>flow_03</bpmn:incoming>
      <bpmn:outgoing>flow_04</bpmn:outgoing>
      <bpmn:outgoing>flow_05</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:task id="task_03_kuendigung_schreiben" name="Kündigung schreiben (TQ.21.00.00.70.03)">
      <bpmn:incoming>flow_04</bpmn:incoming>
      <bpmn:outgoing>flow_06</bpmn:outgoing>
    </bpmn:task>

    <bpmn:task id="task_04_kuendigung_entgegennehmen" name="Kündigung entgegennehmen (TQ.21.00.00.70.04)">
      <bpmn:incoming>flow_05</bpmn:incoming>
      <bpmn:outgoing>flow_07</bpmn:outgoing>
    </bpmn:task>

    <bpmn:task id="task_05_kuendigung_pruefen" name="Kündigung prüfen (TQ.21.00.00.70.05)">
      <bpmn:incoming>flow_07</bpmn:incoming>
      <bpmn:outgoing>flow_08</bpmn:outgoing>
    </bpmn:task>

    <bpmn:exclusiveGateway id="gw_02" name="Kündigung OK?">
      <bpmn:incoming>flow_08</bpmn:incoming>
      <bpmn:outgoing>flow_09</bpmn:outgoing>
      <bpmn:outgoing>flow_10</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:task id="task_06_bewirtschaftung" name="TQ.21.00.00.30 Bewirtschaftung Anmiet-/Pachtverträge, Eigene Baurechte (TQ.21.00.00.70.06)">
      <bpmn:incoming>flow_10</bpmn:incoming>
      <bpmn:outgoing>flow_11</bpmn:outgoing>
    </bpmn:task>

    <bpmn:exclusiveGateway id="gw_merge" name="">
      <bpmn:incoming>flow_06</bpmn:incoming>
      <bpmn:incoming>flow_09</bpmn:incoming>
      <bpmn:outgoing>flow_12</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:task id="task_07_folgetaetigkeiten" name="Folgetätigkeiten auslösen (TQ.21.00.00.70.07)">
      <bpmn:incoming>flow_12</bpmn:incoming>
      <bpmn:outgoing>flow_13</bpmn:outgoing>
    </bpmn:task>

    <bpmn:task id="task_08_orientieren_uebergeben" name="Orientieren, Geschäft übergeben (TQ.21.00.00.70.08)">
      <bpmn:incoming>flow_13</bpmn:incoming>
      <bpmn:outgoing>flow_14</bpmn:outgoing>
    </bpmn:task>

    <bpmn:task id="task_09_umsetzung_unterhalt" name="TQ.21.03.03.50 Umsetzung Unterhalt und Kleinprojekte (TQ.21.00.00.70.09)">
      <bpmn:incoming>flow_14</bpmn:incoming>
      <bpmn:outgoing>flow_15</bpmn:outgoing>
    </bpmn:task>

    <bpmn:task id="task_10_sap_fertigmeldung" name="SAP Fertigmeldung absetzen (TQ.21.00.00.70.10)">
      <bpmn:incoming>flow_15</bpmn:incoming>
      <bpmn:outgoing>flow_16</bpmn:outgoing>
    </bpmn:task>

    <bpmn:endEvent id="end_1" name="TQ Auflösung Anmiete, Pacht abgeschlossen">
      <bpmn:incoming>flow_11</bpmn:incoming>
      <bpmn:incoming>flow_16</bpmn:incoming>
    </bpmn:endEvent>

    <!-- Sequence flows -->
