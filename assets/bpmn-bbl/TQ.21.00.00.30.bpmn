      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="edge_flow_04" bpmnElement="flow_04">
        <di:waypoint x="740" y="480"/>
        <di:waypoint x="790" y="480"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="edge_flow_05" bpmnElement="flow_05">
