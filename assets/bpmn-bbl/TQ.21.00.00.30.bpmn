      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="edge_flow_06" bpmnElement="flow_06">
        <di:waypoint x="1040" y="480"/>
        <di:waypoint x="1090" y="480"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="edge_flow_07" bpmnElement="flow_07">
        <di:waypoint x="1190" y="480"/>
        <di:waypoint x="1240" y="480"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="edge_flow_08" bpmnElement="flow_08">
        <di:waypoint x="1265" y="455"/>
        <di:waypoint x="1265" y="280"/>
        <di:waypoint x="1340" y="280"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="edge_flow_09" bpmnElement="flow_09">
        <di:waypoint x="1265" y="455"/>
        <di:waypoint x="1265" y="370"/>
        <di:waypoint x="1340" y="370"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="edge_flow_10" bpmnElement="flow_10">
        <di:waypoint x="1290" y="480"/>
        <di:waypoint x="1320" y="480"/>
        <di:waypoint x="1320" y="460"/>
        <di:waypoint x="1340" y="460"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="edge_flow_11" bpmnElement="flow_11">
        <di:waypoint x="1265" y="505"/>
        <di:waypoint x="1265" y="550"/>
        <di:waypoint x="1340" y="550"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="edge_flow_12" bpmnElement="flow_12">
