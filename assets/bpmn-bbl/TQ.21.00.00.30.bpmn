        <di:waypoint x="1265" y="640"/>
        <di:waypoint x="1340" y="640"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="edge_flow_13" bpmnElement="flow_13">
        <di:waypoint x="1265" y="505"/>
        <di:waypoint x="1265" y="710"/>
        <di:waypoint x="1340" y="710"/>
      </bpmndi:BPMNEdge>
      <!-- task_12 edge remains aligned at y=710 (task center) -->

      <bpmndi:BPMNEdge id="edge_flow_14" bpmnElement="flow_14">
        <di:waypoint x="1440" y="280"/>
        <di:waypoint x="1525" y="280"/>
        <di:waypoint x="1525" y="455"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="edge_flow_15" bpmnElement="flow_15">
        <di:waypoint x="1440" y="370"/>
        <di:waypoint x="1525" y="370"/>
        <di:waypoint x="1525" y="455"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="edge_flow_16" bpmnElement="flow_16">
        <di:waypoint x="1440" y="460"/>
        <di:waypoint x="1475" y="460"/>
        <di:waypoint x="1475" y="480"/>
        <di:waypoint x="1500" y="480"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="edge_flow_17" bpmnElement="flow_17">
        <di:waypoint x="1440" y="550"/>
