    <!-- Start event -->
    <bpmn:startEvent id="start_1" name="TQ Kündigung Anmiete / Verkauf liegt vor">
      <bpmn:outgoing>flow_01</bpmn:outgoing>
    </bpmn:startEvent>

    <!-- Main flow tasks -->
    <bpmn:task id="task_01_objektrueckgabe_vorbereiten" name="Objektrückgabe vorbereiten (TQ.21.00.00.90.01)">
      <bpmn:incoming>flow_01</bpmn:incoming>
      <bpmn:outgoing>flow_02</bpmn:outgoing>
    </bpmn:task>

    <bpmn:task id="task_02_objektrueckgabe_vor_ort" name="Objektrückgabe vor Ort durchführen (TQ.21.00.00.90.02)">
