        <di:waypoint x="340" y="360"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="edge_flow_02" bpmnElement="flow_02">
        <di:waypoint x="440" y="360"/>
        <di:waypoint x="490" y="360"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="edge_flow_03" bpmnElement="flow_03">
        <di:waypoint x="515" y="335"/>
        <di:waypoint x="515" y="240"/>
        <di:waypoint x="620" y="240"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="edge_flow_04" bpmnElement="flow_04">
        <di:waypoint x="540" y="360"/>
        <di:waypoint x="620" y="360"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="edge_flow_05" bpmnElement="flow_05">
        <di:waypoint x="515" y="385"/>
        <di:waypoint x="515" y="490"/>
        <di:waypoint x="620" y="490"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="edge_flow_06" bpmnElement="flow_06">
        <di:waypoint x="720" y="240"/>
        <di:waypoint x="770" y="240"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="edge_flow_07" bpmnElement="flow_07">
        <di:waypoint x="720" y="360"/>
        <di:waypoint x="770" y="360"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="edge_flow_08" bpmnElement="flow_08">
        <di:waypoint x="720" y="490"/>
        <di:waypoint x="770" y="490"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="edge_flow_09" bpmnElement="flow_09">
        <di:waypoint x="820" y="360"/>
