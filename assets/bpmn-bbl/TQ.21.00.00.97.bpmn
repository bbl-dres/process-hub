      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="shape_lane_aktenmanagement" bpmnElement="lane_aktenmanagement" isHorizontal="true">
        <dc:Bounds x="200" y="160" width="1600" height="420"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="shape_lane_umsetzer" bpmnElement="lane_umsetzer" isHorizontal="true">
        <dc:Bounds x="200" y="580" width="1600" height="120"/>
      </bpmndi:BPMNShape>

      <!-- Aktenmanagement lane nodes -->
      <bpmndi:BPMNShape id="shape_start_1" bpmnElement="start_1">
        <dc:Bounds x="260" y="342" width="36" height="36"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="shape_task_01" bpmnElement="task_01_eingang_pruefen">
        <dc:Bounds x="340" y="320" width="100" height="80"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="shape_gw_01" bpmnElement="gw_01" isMarkerVisible="true">
        <dc:Bounds x="490" y="335" width="50" height="50"/>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="shape_task_04" bpmnElement="task_04_akten_abgeben_zuruecknehmen">
        <dc:Bounds x="620" y="200" width="100" height="80"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="shape_end_akten_abgegeben" bpmnElement="end_akten_abgegeben">
        <dc:Bounds x="770" y="222" width="36" height="36"/>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="shape_task_02" bpmnElement="task_02_akten_pruefen_registrieren">
        <dc:Bounds x="620" y="320" width="100" height="80"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="shape_gw_merge" bpmnElement="gw_merge" isMarkerVisible="true">
        <dc:Bounds x="770" y="335" width="50" height="50"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="shape_task_03" bpmnElement="task_03_akten_archivieren">
        <dc:Bounds x="860" y="320" width="100" height="80"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="shape_end_eingang_bearbeitet" bpmnElement="end_eingang_bearbeitet">
        <dc:Bounds x="1010" y="342" width="36" height="36"/>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="shape_task_05" bpmnElement="task_05_akten_aufbewahren_lieferscheine">
        <dc:Bounds x="620" y="450" width="100" height="80"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="shape_end_akten_aufbewahrt" bpmnElement="end_akten_aufbewahrt">
        <dc:Bounds x="770" y="472" width="36" height="36"/>
      </bpmndi:BPMNShape>

      <!-- Edges -->
      <bpmndi:BPMNEdge id="edge_flow_01" bpmnElement="flow_01">
