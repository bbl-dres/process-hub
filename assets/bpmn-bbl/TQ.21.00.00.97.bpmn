<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions
    xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL"
    xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI"
    xmlns:dc="http://www.omg.org/spec/DD/20100524/DC"
    xmlns:di="http://www.omg.org/spec/DD/20100524/DI"
    id="definitions_TQ_21_00_00_97"
    targetNamespace="http://process-hub.local/bpmn">
  <bpmn:process id="proc_TQ_21_00_00_97" name="TQ.21.00.00.97 Aktenmanagement" isExecutable="false">
    <bpmn:laneSet id="laneSet_1">
      <bpmn:lane id="lane_auftraggeber" name="TQ Auftraggeber/in"/>
      <bpmn:lane id="lane_aktenmanagement" name="TQ.21.00.00.97 Aktenmanagement">
        <bpmn:flowNodeRef>start_1</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>task_01_eingang_pruefen</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>gw_01</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>task_02_akten_pruefen_registrieren</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>task_04_akten_abgeben_zuruecknehmen</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>task_05_akten_aufbewahren_lieferscheine</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>gw_merge</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>task_03_akten_archivieren</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>end_eingang_bearbeitet</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>end_akten_abgegeben</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>end_akten_aufbewahrt</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="lane_umsetzer" name="TQ.03 Umsetzer/innen denkbar (M)"/>
    </bpmn:laneSet>

    <!-- Start event -->
    <bpmn:startEvent id="start_1" name="TQ Eingang Aktenmanagement">
      <bpmn:outgoing>flow_01</bpmn:outgoing>
    </bpmn:startEvent>

    <!-- Tasks -->
    <bpmn:task id="task_01_eingang_pruefen" name="Eingang prüfen (TQ.21.00.00.97.F01)">
      <bpmn:incoming>flow_01</bpmn:incoming>
      <bpmn:outgoing>flow_02</bpmn:outgoing>
    </bpmn:task>

    <bpmn:exclusiveGateway id="gw_01" name="">
      <bpmn:incoming>flow_02</bpmn:incoming>
      <bpmn:outgoing>flow_03</bpmn:outgoing>
      <bpmn:outgoing>flow_04</bpmn:outgoing>
      <bpmn:outgoing>flow_05</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:task id="task_04_akten_abgeben_zuruecknehmen" name="Akten abgeben und zurücknehmen (TQ.21.00.00.97.04)">
      <bpmn:incoming>flow_03</bpmn:incoming>
      <bpmn:outgoing>flow_06</bpmn:outgoing>
    </bpmn:task>

    <bpmn:task id="task_02_akten_pruefen_registrieren" name="Akten prüfen / registrieren (TQ.21.00.00.97.02)">
      <bpmn:incoming>flow_04</bpmn:incoming>
      <bpmn:outgoing>flow_07</bpmn:outgoing>
    </bpmn:task>

    <bpmn:task id="task_05_akten_aufbewahren_lieferscheine" name="Akten aufbewahren und Lieferscheine erstellen (TQ.21.00.00.97.A06)">
      <bpmn:incoming>flow_05</bpmn:incoming>
      <bpmn:outgoing>flow_08</bpmn:outgoing>
    </bpmn:task>

    <bpmn:exclusiveGateway id="gw_merge" name="">
      <bpmn:incoming>flow_07</bpmn:incoming>
      <bpmn:outgoing>flow_09</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:task id="task_03_akten_archivieren" name="Akten archivieren (TQ.21.00.00.97.03)">
      <bpmn:incoming>flow_09</bpmn:incoming>
      <bpmn:outgoing>flow_10</bpmn:outgoing>
    </bpmn:task>

    <!-- End events -->
    <bpmn:endEvent id="end_akten_abgegeben" name="TQ Akten abgegeben / zurückgenommen">
      <bpmn:incoming>flow_06</bpmn:incoming>
    </bpmn:endEvent>

    <bpmn:endEvent id="end_eingang_bearbeitet" name="TQ Akten archiviert">
      <bpmn:incoming>flow_10</bpmn:incoming>
    </bpmn:endEvent>

    <bpmn:endEvent id="end_akten_aufbewahrt" name="TQ Akten aufbewahrt">
      <bpmn:incoming>flow_08</bpmn:incoming>
    </bpmn:endEvent>

    <!-- Sequence flows -->
    <bpmn:sequenceFlow id="flow_01" sourceRef="start_1" targetRef="task_01_eingang_pruefen"/>
    <bpmn:sequenceFlow id="flow_02" sourceRef="task_01_eingang_pruefen" targetRef="gw_01"/>
    <bpmn:sequenceFlow id="flow_03" name="abgeben / zurücknehmen" sourceRef="gw_01" targetRef="task_04_akten_abgeben_zuruecknehmen"/>
    <bpmn:sequenceFlow id="flow_04" name="prüfen / registrieren" sourceRef="gw_01" targetRef="task_02_akten_pruefen_registrieren"/>
    <bpmn:sequenceFlow id="flow_05" name="aufbewahren" sourceRef="gw_01" targetRef="task_05_akten_aufbewahren_lieferscheine"/>
    <bpmn:sequenceFlow id="flow_06" sourceRef="task_04_akten_abgeben_zuruecknehmen" targetRef="end_akten_abgegeben"/>
    <bpmn:sequenceFlow id="flow_07" sourceRef="task_02_akten_pruefen_registrieren" targetRef="gw_merge"/>
    <bpmn:sequenceFlow id="flow_08" sourceRef="task_05_akten_aufbewahren_lieferscheine" targetRef="end_akten_aufbewahrt"/>
    <bpmn:sequenceFlow id="flow_09" sourceRef="gw_merge" targetRef="task_03_akten_archivieren"/>
    <bpmn:sequenceFlow id="flow_10" sourceRef="task_03_akten_archivieren" targetRef="end_eingang_bearbeitet"/>
  </bpmn:process>

  <bpmndi:BPMNDiagram id="BPMNDiagram_1">
    <bpmndi:BPMNPlane id="BPMNPlane_1" bpmnElement="proc_TQ_21_00_00_97">

