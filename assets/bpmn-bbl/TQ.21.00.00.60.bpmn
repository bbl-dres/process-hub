      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="shape_gw_01_split" bpmnElement="gw_01_split" isMarkerVisible="true">
        <dc:Bounds x="490" y="275" width="50" height="50"/>
      </bpmndi:BPMNShape>

      <!-- Anmiete path (upper in IM lane) -->
      <bpmndi:BPMNShape id="shape_task_02" bpmnElement="task_02_mieter_rueckbau_verhandeln">
        <dc:Bounds x="600" y="190" width="100" height="80"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="shape_task_03" bpmnElement="task_03_schlussbericht_anmiete">
        <dc:Bounds x="750" y="190" width="100" height="80"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="shape_task_04" bpmnElement="task_04_dossier_weiterleiten_anmiete">
        <dc:Bounds x="900" y="190" width="100" height="80"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="shape_end_anmiete" bpmnElement="end_anmiete">
        <dc:Bounds x="1050" y="212" width="36" height="36"/>
      </bpmndi:BPMNShape>

      <!-- Verkauf path (lower in IM lane) -->
      <bpmndi:BPMNShape id="shape_task_05" bpmnElement="task_05_objektwert_ermitteln">
        <dc:Bounds x="600" y="370" width="100" height="80"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="shape_subproc_06" bpmnElement="subproc_06_bim_bauen">
        <dc:Bounds x="750" y="370" width="120" height="80"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="shape_task_07" bpmnElement="task_07_fiaa_abgleich">
        <dc:Bounds x="920" y="370" width="100" height="80"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="shape_task_08" bpmnElement="task_08_hoechstangebot_ermitteln">
        <dc:Bounds x="1070" y="370" width="100" height="80"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="shape_task_09" bpmnElement="task_09_schlussbericht_verkauf">
        <dc:Bounds x="1220" y="370" width="100" height="80"/>
      </bpmndi:BPMNShape>

      <!-- Entscheider lane node -->
      <bpmndi:BPMNShape id="shape_task_10" bpmnElement="task_10_antrag_genehmigen">
        <dc:Bounds x="1370" y="510" width="100" height="80"/>
      </bpmndi:BPMNShape>

      <!-- Back to IM lane -->
      <bpmndi:BPMNShape id="shape_task_11" bpmnElement="task_11_dossier_weiterleiten_verkauf">
        <dc:Bounds x="1520" y="370" width="100" height="80"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="shape_end_verkauf" bpmnElement="end_verkauf">
        <dc:Bounds x="1670" y="392" width="36" height="36"/>
      </bpmndi:BPMNShape>

      <!-- Edges -->
      <bpmndi:BPMNEdge id="edge_flow_01" bpmnElement="flow_01">
        <di:waypoint x="296" y="300"/>
        <di:waypoint x="340" y="300"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="edge_flow_02" bpmnElement="flow_02">
