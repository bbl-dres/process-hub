<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions
    xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL"
    xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI"
    xmlns:dc="http://www.omg.org/spec/DD/20100524/DC"
    xmlns:di="http://www.omg.org/spec/DD/20100524/DI"
    id="definitions_TQ_21_00_00_60"
    targetNamespace="http://process-hub.local/bpmn">
  <bpmn:process id="proc_TQ_21_00_00_60" name="TQ.21.00.00.60 Lösungsvorschläge Rückgabe Anmietobjekt, Verkauf" isExecutable="false">
    <bpmn:laneSet id="laneSet_1">
      <bpmn:lane id="lane_auftraggeber" name="TQ Auftraggeber/in"/>
      <bpmn:lane id="lane_im" name="TQ Immobilienmanager/in">
        <bpmn:flowNodeRef>start_1</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>task_01_auftrag_entgegennehmen</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>gw_01_split</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>task_02_mieter_rueckbau_verhandeln</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>task_03_schlussbericht_anmiete</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>task_04_dossier_weiterleiten_anmiete</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>end_anmiete</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>task_05_objektwert_ermitteln</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>subproc_06_bim_bauen</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>task_07_fiaa_abgleich</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>task_08_hoechstangebot_ermitteln</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>task_09_schlussbericht_verkauf</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>task_11_dossier_weiterleiten_verkauf</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>end_verkauf</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="lane_entscheider" name="TQ Entscheidungsträger/in">
        <bpmn:flowNodeRef>task_10_antrag_genehmigen</bpmn:flowNodeRef>
      </bpmn:lane>
    </bpmn:laneSet>

    <!-- Start event -->
    <bpmn:startEvent id="start_1" name="TQ Auftrag Lösungsvorschlag Rückgabe / Verkauf">
      <bpmn:outgoing>flow_01</bpmn:outgoing>
    </bpmn:startEvent>

    <!-- Common entry task -->
    <bpmn:task id="task_01_auftrag_entgegennehmen" name="Auftrag entgegennehmen (TQ.21.00.00.60.01)">
      <bpmn:incoming>flow_01</bpmn:incoming>
      <bpmn:outgoing>flow_02</bpmn:outgoing>
    </bpmn:task>

    <!-- Split: Anmiete vs. Verkauf -->
    <bpmn:exclusiveGateway id="gw_01_split" name="">
      <bpmn:incoming>flow_02</bpmn:incoming>
      <bpmn:outgoing>flow_03</bpmn:outgoing>
      <bpmn:outgoing>flow_04</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <!-- Anmiete path -->
    <bpmn:task id="task_02_mieter_rueckbau_verhandeln" name="Mieter/Rückbau verhandeln (TQ.21.00.00.60.02)">
      <bpmn:incoming>flow_03</bpmn:incoming>
      <bpmn:outgoing>flow_05</bpmn:outgoing>
    </bpmn:task>

    <bpmn:task id="task_03_schlussbericht_anmiete" name="Schlussbericht mit Empfehlung erstellen (TQ.21.00.00.60.03)">
      <bpmn:incoming>flow_05</bpmn:incoming>
      <bpmn:outgoing>flow_06</bpmn:outgoing>
    </bpmn:task>

    <bpmn:task id="task_04_dossier_weiterleiten_anmiete" name="Dossier weiterleiten (TQ.21.00.00.60.04)">
      <bpmn:incoming>flow_06</bpmn:incoming>
      <bpmn:outgoing>flow_07</bpmn:outgoing>
    </bpmn:task>

    <bpmn:endEvent id="end_anmiete" name="TQ Dossier Rückgabe Anmiete weitergeleitet">
      <bpmn:incoming>flow_07</bpmn:incoming>
    </bpmn:endEvent>

    <!-- Verkauf path -->
    <bpmn:task id="task_05_objektwert_ermitteln" name="Objektwert ermitteln (TQ.21.00.00.60.05)">
      <bpmn:incoming>flow_04</bpmn:incoming>
      <bpmn:outgoing>flow_08</bpmn:outgoing>
    </bpmn:task>

    <bpmn:subProcess id="subproc_06_bim_bauen" name="TQ.21.00.00.95 BIM-Prozess Bauen (TQ.21.00.00.60.06)">
      <bpmn:incoming>flow_08</bpmn:incoming>
      <bpmn:outgoing>flow_09</bpmn:outgoing>
    </bpmn:subProcess>

    <bpmn:task id="task_07_fiaa_abgleich" name="Abgleich mit FIAA durchführen (TQ.21.00.00.60.07)">
      <bpmn:incoming>flow_09</bpmn:incoming>
      <bpmn:outgoing>flow_10</bpmn:outgoing>
    </bpmn:task>

    <bpmn:task id="task_08_hoechstangebot_ermitteln" name="Höchstangebot ermitteln (TQ.21.00.00.60.08)">
      <bpmn:incoming>flow_10</bpmn:incoming>
      <bpmn:outgoing>flow_11</bpmn:outgoing>
    </bpmn:task>

    <bpmn:task id="task_09_schlussbericht_verkauf" name="Schlussbericht mit Empfehlung erstellen (TQ.21.00.00.60.09)">
      <bpmn:incoming>flow_11</bpmn:incoming>
      <bpmn:outgoing>flow_12</bpmn:outgoing>
    </bpmn:task>

    <bpmn:task id="task_10_antrag_genehmigen" name="Antrag genehmigen (TQ.21.00.00.60.10)">
      <bpmn:incoming>flow_12</bpmn:incoming>
      <bpmn:outgoing>flow_13</bpmn:outgoing>
    </bpmn:task>

    <bpmn:task id="task_11_dossier_weiterleiten_verkauf" name="Dossier weiterleiten (TQ.21.00.00.60.11)">
      <bpmn:incoming>flow_13</bpmn:incoming>
      <bpmn:outgoing>flow_14</bpmn:outgoing>
    </bpmn:task>

    <bpmn:endEvent id="end_verkauf" name="TQ Dossier Verkauf weitergeleitet">
      <bpmn:incoming>flow_14</bpmn:incoming>
    </bpmn:endEvent>

    <!-- Sequence flows -->
    <bpmn:sequenceFlow id="flow_01" sourceRef="start_1" targetRef="task_01_auftrag_entgegennehmen"/>
    <bpmn:sequenceFlow id="flow_02" sourceRef="task_01_auftrag_entgegennehmen" targetRef="gw_01_split"/>
    <bpmn:sequenceFlow id="flow_03" name="Rückgabe Anmietobjekt" sourceRef="gw_01_split" targetRef="task_02_mieter_rueckbau_verhandeln"/>
    <bpmn:sequenceFlow id="flow_04" name="Verkauf" sourceRef="gw_01_split" targetRef="task_05_objektwert_ermitteln"/>
    <bpmn:sequenceFlow id="flow_05" sourceRef="task_02_mieter_rueckbau_verhandeln" targetRef="task_03_schlussbericht_anmiete"/>
    <bpmn:sequenceFlow id="flow_06" sourceRef="task_03_schlussbericht_anmiete" targetRef="task_04_dossier_weiterleiten_anmiete"/>
    <bpmn:sequenceFlow id="flow_07" sourceRef="task_04_dossier_weiterleiten_anmiete" targetRef="end_anmiete"/>
    <bpmn:sequenceFlow id="flow_08" sourceRef="task_05_objektwert_ermitteln" targetRef="subproc_06_bim_bauen"/>
    <bpmn:sequenceFlow id="flow_09" sourceRef="subproc_06_bim_bauen" targetRef="task_07_fiaa_abgleich"/>
    <bpmn:sequenceFlow id="flow_10" sourceRef="task_07_fiaa_abgleich" targetRef="task_08_hoechstangebot_ermitteln"/>
    <bpmn:sequenceFlow id="flow_11" sourceRef="task_08_hoechstangebot_ermitteln" targetRef="task_09_schlussbericht_verkauf"/>
    <bpmn:sequenceFlow id="flow_12" sourceRef="task_09_schlussbericht_verkauf" targetRef="task_10_antrag_genehmigen"/>
    <bpmn:sequenceFlow id="flow_13" sourceRef="task_10_antrag_genehmigen" targetRef="task_11_dossier_weiterleiten_verkauf"/>
    <bpmn:sequenceFlow id="flow_14" sourceRef="task_11_dossier_weiterleiten_verkauf" targetRef="end_verkauf"/>
  </bpmn:process>

  <bpmndi:BPMNDiagram id="BPMNDiagram_1">
    <bpmndi:BPMNPlane id="BPMNPlane_1" bpmnElement="proc_TQ_21_00_00_60">

