      <bpmndi:BPMNEdge id="edge_flow_06" bpmnElement="flow_06">
        <di:waypoint x="850" y="230"/>
        <di:waypoint x="900" y="230"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="edge_flow_07" bpmnElement="flow_07">
        <di:waypoint x="1000" y="230"/>
        <di:waypoint x="1050" y="230"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="edge_flow_08" bpmnElement="flow_08">
        <di:waypoint x="700" y="410"/>
        <di:waypoint x="750" y="410"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="edge_flow_09" bpmnElement="flow_09">
        <di:waypoint x="870" y="410"/>
        <di:waypoint x="920" y="410"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="edge_flow_10" bpmnElement="flow_10">
        <di:waypoint x="1020" y="410"/>
        <di:waypoint x="1070" y="410"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="edge_flow_11" bpmnElement="flow_11">
        <di:waypoint x="1170" y="410"/>
        <di:waypoint x="1220" y="410"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="edge_flow_12" bpmnElement="flow_12">
        <di:waypoint x="1320" y="410"/>
        <di:waypoint x="1420" y="410"/>
        <di:waypoint x="1420" y="510"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="edge_flow_13" bpmnElement="flow_13">
        <di:waypoint x="1470" y="550"/>
        <di:waypoint x="1570" y="550"/>
        <di:waypoint x="1570" y="450"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="edge_flow_14" bpmnElement="flow_14">
        <di:waypoint x="1620" y="410"/>
        <di:waypoint x="1670" y="410"/>
      </bpmndi:BPMNEdge>

    </bpmndi:BPMNPlane>
  </bpmndi:BPMNDiagram>
