      <bpmndi:BPMNShape id="shape_lane_auftraggeber" bpmnElement="lane_auftraggeber" isHorizontal="true">
        <dc:Bounds x="200" y="40" width="2100" height="120"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="shape_lane_im" bpmnElement="lane_im" isHorizontal="true">
        <dc:Bounds x="200" y="160" width="2100" height="320"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="shape_lane_entscheider" bpmnElement="lane_entscheider" isHorizontal="true">
        <dc:Bounds x="200" y="480" width="2100" height="140"/>
      </bpmndi:BPMNShape>

      <!-- IM lane nodes -->
      <bpmndi:BPMNShape id="shape_start_1" bpmnElement="start_1">
        <dc:Bounds x="260" y="282" width="36" height="36"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="shape_task_01" bpmnElement="task_01_auftrag_entgegennehmen">
