    targetNamespace="http://process-hub.local/bpmn">
  <bpmn:process id="proc_TQ_21_00_00_96" name="TQ.21.00.00.96 Immostammdaten Energiedatenverwaltung" isExecutable="false">
    <bpmn:laneSet id="laneSet_1">
      <bpmn:lane id="lane_collaboration_sap" name="CollaborationSAP"/>
      <bpmn:lane id="lane_immostammdatenmanager" name="TQ Immostammdatenmanager/in">
        <bpmn:flowNodeRef>start_1</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>task_01_eingang_pruefen</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>gw_01</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>task_05_stammdaten_anlegen_pflegen</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>task_03_daten_plausibilisieren</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>task_04_daten_eingeben</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>gw_02</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>task_06_information_weitergeben</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>end_1</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="lane_objektmanagement" name="TQ Objektmanagement">
        <bpmn:flowNodeRef>task_02_energiedaten_ablesen</bpmn:flowNodeRef>
      </bpmn:lane>
    </bpmn:laneSet>

    <!-- Start event -->
    <bpmn:startEvent id="start_1" name="TQ Allgemeine Mutationsmeldungen und Ersterfassungen TQ Stammdatenblatt">
      <bpmn:outgoing>flow_01</bpmn:outgoing>
    </bpmn:startEvent>

    <!-- Tasks -->
    <bpmn:task id="task_01_eingang_pruefen" name="Eingang prüfen (TQ.21.00.00.96.01)">
      <bpmn:incoming>flow_01</bpmn:incoming>
      <bpmn:outgoing>flow_02</bpmn:outgoing>
    </bpmn:task>

    <bpmn:exclusiveGateway id="gw_01" name="">
      <bpmn:incoming>flow_02</bpmn:incoming>
      <bpmn:outgoing>flow_03</bpmn:outgoing>
      <bpmn:outgoing>flow_04</bpmn:outgoing>
      <bpmn:outgoing>flow_05</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:task id="task_05_stammdaten_anlegen_pflegen" name="Stammdaten anlegen / pflegen (TQ.21.00.00.96.05)">
      <bpmn:incoming>flow_03</bpmn:incoming>
      <bpmn:outgoing>flow_06</bpmn:outgoing>
    </bpmn:task>

    <bpmn:task id="task_03_daten_plausibilisieren" name="Daten plausibilisieren (TQ.21.00.00.96.03)">
      <bpmn:incoming>flow_04</bpmn:incoming>
      <bpmn:outgoing>flow_07</bpmn:outgoing>
    </bpmn:task>

    <bpmn:task id="task_04_daten_eingeben" name="Daten eingeben (TQ.21.00.00.96.04)">
      <bpmn:incoming>flow_07</bpmn:incoming>
      <bpmn:outgoing>flow_08</bpmn:outgoing>
    </bpmn:task>

    <bpmn:task id="task_02_energiedaten_ablesen" name="Energiedaten ablesen (TQ.21.00.00.96.02)">
      <bpmn:incoming>flow_05</bpmn:incoming>
      <bpmn:outgoing>flow_09</bpmn:outgoing>
    </bpmn:task>

    <bpmn:exclusiveGateway id="gw_02" name="">
      <bpmn:incoming>flow_06</bpmn:incoming>
      <bpmn:incoming>flow_08</bpmn:incoming>
      <bpmn:incoming>flow_09</bpmn:incoming>
      <bpmn:outgoing>flow_10</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:task id="task_06_information_weitergeben" name="Information weitergeben (TQ.21.00.00.96.06)">
      <bpmn:incoming>flow_10</bpmn:incoming>
      <bpmn:outgoing>flow_11</bpmn:outgoing>
    </bpmn:task>

    <bpmn:endEvent id="end_1" name="TQ Vollzugsmeldung Anmiete Pacht / TQ Stammdaten erfasst Verurkundung Kauf Baurecht / Meldung TQ.21.00.00.96 Immostammdaten Energiedatenverwaltung">
      <bpmn:incoming>flow_11</bpmn:incoming>
    </bpmn:endEvent>

    <!-- Sequence flows -->
    <bpmn:sequenceFlow id="flow_01" sourceRef="start_1" targetRef="task_01_eingang_pruefen"/>
    <bpmn:sequenceFlow id="flow_02" sourceRef="task_01_eingang_pruefen" targetRef="gw_01"/>
    <bpmn:sequenceFlow id="flow_03" name="Immobilienstammdaten (SAP RE)" sourceRef="gw_01" targetRef="task_05_stammdaten_anlegen_pflegen"/>
    <bpmn:sequenceFlow id="flow_04" name="ESTAT / RUMBA" sourceRef="gw_01" targetRef="task_03_daten_plausibilisieren"/>
    <bpmn:sequenceFlow id="flow_05" sourceRef="gw_01" targetRef="task_02_energiedaten_ablesen"/>
    <bpmn:sequenceFlow id="flow_06" sourceRef="task_05_stammdaten_anlegen_pflegen" targetRef="gw_02"/>
    <bpmn:sequenceFlow id="flow_07" sourceRef="task_03_daten_plausibilisieren" targetRef="task_04_daten_eingeben"/>
    <bpmn:sequenceFlow id="flow_08" sourceRef="task_04_daten_eingeben" targetRef="gw_02"/>
    <bpmn:sequenceFlow id="flow_09" sourceRef="task_02_energiedaten_ablesen" targetRef="gw_02"/>
    <bpmn:sequenceFlow id="flow_10" sourceRef="gw_02" targetRef="task_06_information_weitergeben"/>
    <bpmn:sequenceFlow id="flow_11" sourceRef="task_06_information_weitergeben" targetRef="end_1"/>
  </bpmn:process>

  <bpmndi:BPMNDiagram id="BPMNDiagram_1">
