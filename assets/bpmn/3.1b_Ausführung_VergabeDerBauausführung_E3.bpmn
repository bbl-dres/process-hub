  <bpmn20:globalTask id="c95ea745-4b70-4c6d-935d-777dbb44feb4" name="Fotodokumentation erstellen" aeneis:aenuid="_c53db652-42a3-4ef7-9221-8691cdf6ea32_49e9cc6d-d133-4ca9-8078-513ada5ad920" aeneis:aenmodeluid="c95ea745-4b70-4c6d-935d-777dbb44feb4">
    <bpmn20:documentation id="_c53db652-42a3-4ef7-9221-8691cdf6ea32_49e9cc6d-d133-4ca9-8078-513ada5ad920_description_plain">Beweissicherung durch Dokumentation : der Baufeldbeschaffenheit (der aufgeführten Punkte) der Randbedigungen für die Logistik (der aufgeführten Punkte) der Bestandsmedien (Versorgungsleitungen bzw. Anschlüsse )</bpmn20:documentation>
    <bpmn20:documentation id="_c53db652-42a3-4ef7-9221-8691cdf6ea32_49e9cc6d-d133-4ca9-8078-513ada5ad920_description_html" textFormat="text/html" />
  </bpmn20:globalTask>
  <bpmn20:globalTask id="e4af486d-a4dc-46fb-92a4-66a2f72b8dee" name="Randbedingungen BE erfassen" aeneis:aenuid="_c53db652-42a3-4ef7-9221-8691cdf6ea32_bc5eca90-f7b2-4bd3-b046-6ca92c41ce7b" aeneis:aenmodeluid="e4af486d-a4dc-46fb-92a4-66a2f72b8dee">
    <bpmn20:documentation id="_c53db652-42a3-4ef7-9221-8691cdf6ea32_bc5eca90-f7b2-4bd3-b046-6ca92c41ce7b_description_plain">Mietflächen von benachbarten Grundstücken/Gebäude (für Büro, Aufenthaltsflächen, Sanitär, sowie Ansprechpartner) Einsatz von Hebezeugen (Krane o. ä.) welche Punkte (augenscheinlich) auf dem Baufeld kommen in Frage Behinderungen berücksichtigen (z.B. Freileitungen, Masten, hohe Bäume, Nachbarbebauung, Neigung des Baufeldes, Baugrundverhältnis)   Quelle: Bundesanstalt für Arbeitsschutz und Arbeitsmedizin &gt; Wirtschaftliche und sicher Baustelleneinrichtung &gt; Chekcliste 1: Baufeldbesichtigung: http://www.baua.de/de/Publikationen/Broschueren/A84.html</bpmn20:documentation>
    <bpmn20:documentation id="_c53db652-42a3-4ef7-9221-8691cdf6ea32_bc5eca90-f7b2-4bd3-b046-6ca92c41ce7b_description_html" textFormat="text/html" />
  </bpmn20:globalTask>
