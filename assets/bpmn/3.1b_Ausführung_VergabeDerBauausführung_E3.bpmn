  <bpmn20:globalTask id="ff7d439b-8d15-4de5-805b-e0ed81c56213" name="Angebotsinhalte zusammenstellen" aeneis:aenuid="_385dc4a6-b9b8-4747-8cbd-38ce439d4354_a679cea6-834b-4e9a-b801-8afbebcb476b" aeneis:aenmodeluid="ff7d439b-8d15-4de5-805b-e0ed81c56213">
    <bpmn20:documentation id="_385dc4a6-b9b8-4747-8cbd-38ce439d4354_a679cea6-834b-4e9a-b801-8afbebcb476b_description_plain">Angebotsbindefrist, Einschränkungen, Ergänzungen, Signatur, Erläuterungen, Auflistung der Angebotsbestandteile Kalkulation Schlussblatt, (Urkalkulation), Positionsliste mit Preisen, Fabrikatsliste, GAEB-Datei, Terminplan, BE-Plan, Organigramm, Grundlage des Angebotes, Sondervorschläge, Nebenangebote, Schnittstellenliste (Wenn nicht klar ist wer was macht), NU-Liste, Geheimhaltungsverpflichtungen, Nachweise der Qualifikation wenn vorher nicht Präqualifikation erfolgt, Referenzen, Bemusterung, Befähigungen, Gütezeichen (Nachhaltigkeits- und sonstige Zertifikate z.B. für ISO 9001)</bpmn20:documentation>
    <bpmn20:documentation id="_385dc4a6-b9b8-4747-8cbd-38ce439d4354_a679cea6-834b-4e9a-b801-8afbebcb476b_description_html" textFormat="text/html" />
  </bpmn20:globalTask>
